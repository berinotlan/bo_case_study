/* MASTHEAD */
.masthead{border-top:4px solid var(--ink);border-bottom:1px solid rgba(240,236,228,.15);padding:0;position:relative;margin-top:48px;}
.masthead-top{border-bottom:1px solid rgba(240,236,228,.1);padding:6px 40px;display:flex;justify-content:space-between;align-items:center;}
.masthead-date{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.05em;}
.masthead-tagline{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}
.masthead-main{padding:20px 40px 16px;text-align:center;position:relative;overflow:hidden;}
.masthead-bg{position:absolute;inset:0;background:linear-gradient(180deg,var(--paper) 0%,#080706 40%,#080706 60%,var(--paper) 100%);}
.masthead-bg img{display:none;}
.masthead-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,var(--paper) 0%,transparent 30%,transparent 70%,var(--paper) 100%);}
.masthead-title{font-family:'Playfair Display',serif;font-size:clamp(80px,16vw,180px);font-weight:900;line-height:.85;letter-spacing:-.02em;color:var(--ink);position:relative;z-index:1;}
.masthead-title .accent{color:var(--rust);font-style:italic;}
.masthead-sub{font-family:'Playfair Display',serif;font-size:clamp(12px,1.5vw,16px);font-style:italic;color:var(--muted);letter-spacing:.08em;margin-top:8px;position:relative;z-index:1;}
.masthead-bottom{border-top:1px solid rgba(240,236,228,.1);padding:6px 40px;display:flex;justify-content:space-between;}
.masthead-bottom-item{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;}
/* LAYOUT */
.container{max-width:1100px;margin:0 auto;padding:0 40px;}
.section{padding:100px 0;}
/* SECTION FLAGS */
.section-flag{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:#0d0c0a;background:var(--ink);padding:4px 12px;display:inline-block;margin-bottom:24px;}
.section-flag.acid{background:var(--rust);color:#0d0c0a;}
.section-flag.warm{background:var(--water);color:#f0ece4;}
/* HEADLINES */
.headline{font-family:'Playfair Display',serif;font-weight:700;line-height:1.05;color:var(--ink);}
.headline-italic{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;line-height:1.1;color:var(--muted);}
/* PULL QUOTE */
.pull-quote{font-family:'Playfair Display',serif;font-size:clamp(20px,3vw,32px);font-style:italic;font-weight:400;color:var(--ink);line-height:1.4;padding:32px 0;border-top:2px solid rgba(240,236,228,.2);border-bottom:2px solid rgba(240,236,228,.2);position:relative;}
.pull-quote::before{content:'"';font-size:80px;color:var(--rust);line-height:1;position:absolute;top:-10px;left:-8px;font-style:normal;}
/* INSIGHT SECTION */
.insight-section{background:var(--dark);padding:100px 0;position:relative;overflow:hidden;}
.insight-section::before{content:'SOMA';position:absolute;font-family:'Playfair Display',serif;font-size:300px;font-weight:900;color:rgba(255,255,255,.015);top:50%;left:50%;transform:translate(-50%,-50%);white-space:nowrap;pointer-events:none;}
.insight-cols{display:grid;grid-template-columns:1fr 1px 1fr;gap:0 48px;margin-top:48px;}
.insight-col-rule{background:rgba(255,255,255,.08);width:1px;}
.insight-step{padding:20px 0;border-bottom:1px solid rgba(255,255,255,.06);}
.insight-step:last-child{border:none;}
.insight-step-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--rust);margin-bottom:8px;}
.insight-step-text{font-size:14px;color:rgba(240,236,228,.6);line-height:1.75;}
.insight-step-text strong{color:rgba(240,236,228,.9);font-weight:500;}
.insight-big{font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,42px);font-style:italic;color:var(--ink);line-height:1.35;}
