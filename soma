.platform-role{font-family:'Playfair Display',serif;font-size:18px;font-style:italic;color:var(--muted);margin-bottom:16px;line-height:1.3;}
.platform-desc{font-size:13px;color:var(--muted);line-height:1.8;}
/* KAMPANYA BÖLÜMÜ */
.kampanya-header{border-top:3px solid rgba(240,236,228,.15);border-bottom:1px solid rgba(240,236,228,.1);padding:40px 0;margin-bottom:64px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:40px;}
.kamp-num{font-family:'Playfair Display',serif;font-size:80px;font-weight:900;color:rgba(240,236,228,.08);line-height:1;}
.kamp-type{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:var(--rust);margin-bottom:8px;}
.kamp-name{font-family:'Playfair Display',serif;font-size:clamp(24px,3vw,40px);font-weight:700;color:var(--ink);line-height:1;}
.kamp-badge{padding:8px 16px;border:1px solid rgba(240,236,228,.15);font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}
/* SENARYO */
.scene-list{display:flex;flex-direction:column;gap:1px;background:rgba(240,236,228,.06);}
.scene{background:var(--cream);padding:28px 32px;}
.scene-tc{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:var(--rust);opacity:.7;line-height:1;margin-bottom:8px;}
.scene-title{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.scene-visual{font-size:12px;line-height:1.75;color:var(--muted);margin-bottom:10px;}
.scene-vo{font-size:13px;line-height:1.7;color:var(--warm);padding:10px 14px;border-left:2px solid var(--rust);background:rgba(200,240,74,.04);margin-top:8px;font-style:italic;}
/* MOCKUP CARDS */
.mock-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px;align-items:start;}
.mock-card{background:var(--cream);border:1px solid rgba(240,236,228,.08);overflow:hidden;display:flex;flex-direction:column;}
.mock-visual{width:100%;height:220px;position:relative;overflow:hidden;}
.mock-visual img{width:100%;height:100%;object-fit:cover;opacity:.85;}
.mock-overlay{position:absolute;inset:0;display:flex;align-items:flex-end;padding:20px;background:linear-gradient(transparent 40%,rgba(6,5,4,.8));}
.mock-overlay-text{font-family:'Playfair Display',serif;font-size:clamp(13px,1.4vw,16px);font-style:italic;line-height:1.4;color:#f0ece4;}
.mock-body{padding:18px 20px;}
.mock-caption{font-size:11px;line-height:1.7;color:var(--muted);margin-bottom:10px;}
.mock-caption strong{color:var(--warm);font-weight:400;font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;}
.mock-meta{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:rgba(200,240,74,.3);display:flex;justify-content:space-between;}
/* BILLBOARD */
.billboard{background:var(--cream);border:1px solid rgba(240,236,228,.08);aspect-ratio:16/7;display:flex;align-items:center;justify-content:space-between;padding:32px 48px;position:relative;overflow:hidden;margin-bottom:16px;}
.billboard::before{content:'';position:absolute;top:0;left:0;bottom:0;width:4px;background:var(--rust);}
.billboard img.bb-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.15;filter:saturate(.4);}
.bb-text{flex:1;position:relative;z-index:1;}
.bb-headline{font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,52px);font-weight:900;letter-spacing:-.01em;line-height:.9;color:var(--ink);}
.bb-headline .bb-outline{-webkit-text-stroke:1px rgba(240,236,228,.3);color:transparent;}
.bb-sub{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-top:12px;}
.bb-logo{font-family:'Playfair Display',serif;font-size:20px;font-weight:900;letter-spacing:.1em;color:rgba(240,236,228,.2);position:relative;z-index:1;text-align:right;}
.bb-location{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);text-align:right;margin-top:4px;}
/* DO / DON'T */
.rules-grid{display:grid;grid-template-columns:1fr 1px 1fr;gap:0;margin-top:48px;border:1px solid rgba(240,236,228,.1);}
.rules-col{padding:40px 36px;}
.rules-col-rule{background:rgba(240,236,228,.08);}
.rules-title{font-family:'Playfair Display',serif;font-size:32px;font-weight:700;margin-bottom:28px;line-height:1;}
.rule-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid rgba(240,236,228,.06);align-items:flex-start;}
.rule-item:last-child{border:none;}
.rule-icon{font-size:14px;flex-shrink:0;margin-top:2px;color:var(--muted);}
.rule-text{font-size:13px;line-height:1.7;color:var(--muted);}
.rule-text em{color:var(--warm);font-style:italic;}
/* ROI TABLE */
.roi-table{width:100%;border-collapse:collapse;margin-top:48px;}
.roi-table th{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);padding:16px 20px;text-align:left;border-bottom:1px solid rgba(240,236,228,.1);background:var(--cream);}
.roi-table td{padding:16px 20px;font-size:13px;color:var(--muted);border-bottom:1px solid rgba(240,236,228,.04);}
.roi-table td:first-child{color:var(--warm);}
.roi-table td.pos{color:var(--rust);}
/* CLOSING */
.closing{background:var(--dark);padding:120px 0;text-align:center;}
.closing-title{font-family:'Playfair Display',serif;font-size:clamp(60px,12vw,140px);font-weight:900;line-height:.85;letter-spacing:-.02em;color:var(--ink);}
.closing-title .accent{color:var(--rust);font-style:italic;}
.closing-sub{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);margin-top:16px;}
.closing-credits{display:flex;justify-content:center;gap:64px;margin-top:64px;padding-top:40px;border-top:1px solid rgba(240,236,228,.08);}
.cred-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.cred-value{font-family:'Playfair Display',serif;font-size:14px;color:var(--ink);}
.cred-value a{color:inherit;text-decoration:none;}
[data-reveal]{opacity:0;transform:translateY(24px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);}
[data-reveal].visible{opacity:1;transform:none;}
@media(max-width:900px){
  .container{padding:0 24px;}
  .masthead-main,.masthead-top,.masthead-bottom{padding-left:24px;padding-right:24px;}
  .kpi-strip,.platform-tabs,.insight-cols,.rules-grid,.mock-grid,.closing-credits{grid-template-columns:1fr;}
  .kampanya-header{grid-template-columns:1fr;gap:16px;}
  .kamp-num{display:none;}
}
</style>
