            <div style="font-size:14px; color:var(--ink);">Yaşlı ama yorulmamış. Çok şey biliyor ama öğretmeye çalışmıyor.</div>
          </div>
          <div style="display:flex; gap:16px; align-items:flex-start;">
            <div style="font-family:'IBM Plex Mono',monospace; font-size:9px; letter-spacing:0.2em; color:var(--rust); width:80px; flex-shrink:0; padding-top:2px;">RENK</div>
            <div style="display:flex; gap:8px; align-items:center;">
              <div style="width:20px;height:20px;border-radius:50%;background:#1c1a14;border:1px solid rgba(0,0,0,0.1);"></div>
              <div style="width:20px;height:20px;border-radius:50%;background:#2c5f8a;"></div>
              <div style="width:20px;height:20px;border-radius:50%;background:#c0392b;"></div>
              <div style="width:20px;height:20px;border-radius:50%;background:#f2ead8;border:1px solid rgba(0,0,0,0.1);"></div>
              <span style="font-size:12px;color:var(--muted);">Mürekkep, su, pas, kağıt</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="identity-grid">
      <div class="identity-cell">
        <div class="identity-cell-title">Ne anlatıyor</div>
        <div class="identity-cell-content">İstanbul'un tatlı kaosunu</div>
