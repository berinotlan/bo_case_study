        </div>
        <div style="margin-top:32px; display:flex; flex-direction:column; gap:16px;">
          <div style="display:flex; gap:16px; align-items:flex-start; padding-bottom:16px; border-bottom:1px solid rgba(28,26,20,0.08);">
            <div style="font-family:'IBM Plex Mono',monospace; font-size:9px; letter-spacing:0.2em; color:var(--rust); width:80px; flex-shrink:0; padding-top:2px;">ISIM</div>
