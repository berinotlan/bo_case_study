<!DOCTYPE html>
<html lang="tr" xml:lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BOĞAZ — Konsept · Berin Otlan</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --paper: #f2ead8;
  --ink: #1c1a14;
  --rust: #c0392b;
  --blue: #1a3a5c;
  --gold: #b8860b;
  --muted: #6b6355;
  --dark: #0f0d09;
  --cream: #faf6ec;
  --water: #2c5f8a;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'IBM Plex Sans', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
}

/* ── NOISE TEXTURE OVERLAY ── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1000;
  opacity: 0.6;
}

/* ── NEWSPAPER MASTHEAD ── */
.masthead {
  border-top: 4px solid var(--ink);
  border-bottom: 1px solid var(--ink);
  padding: 0;
  position: relative;
}
.masthead-top {
  border-bottom: 1px solid var(--ink);
  padding: 6px 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.masthead-date {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 0.05em;
}
.masthead-tagline {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.masthead-main {
  padding: 20px 40px 16px;
  text-align: center;
  position: relative;
}
.masthead-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(80px, 16vw, 180px);
  font-weight: 900;
  line-height: 0.85;
  letter-spacing: -0.02em;
  color: var(--ink);
  position: relative;
}
.masthead-title .water-letter {
  color: var(--water);
  font-style: italic;
}
.masthead-sub {
  font-family: 'Playfair Display', serif;
  font-size: clamp(12px, 1.5vw, 16px);
  font-style: italic;
  color: var(--muted);
  letter-spacing: 0.08em;
  margin-top: 8px;
}
.masthead-bottom {
  border-top: 1px solid var(--ink);
  padding: 6px 40px;
  display: flex;
  justify-content: space-between;
}
.masthead-bottom-item {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ── LAYOUT ── */
.container { max-width: 1100px; margin: 0 auto; padding: 0 40px; }
.section { padding: 100px 0; }

/* ── COLUMN RULES (newspaper vertical lines) ── */
.col-rule {
  width: 1px;
  background: var(--ink);
  opacity: 0.15;
  align-self: stretch;
}

/* ── SECTION HEADERS ── */
.section-flag {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--cream);
  background: var(--ink);
  padding: 4px 12px;
  display: inline-block;
  margin-bottom: 24px;
}
.section-flag.rust { background: var(--rust); }
.section-flag.blue { background: var(--blue); }
.section-flag.water { background: var(--water); }

.headline {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  line-height: 1.05;
  color: var(--ink);
}
.headline-italic {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 400;
  line-height: 1.1;
  color: var(--muted);
}

/* ── PULL QUOTE ── */
.pull-quote {
  font-family: 'Playfair Display', serif;
  font-size: clamp(20px, 3vw, 32px);
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  line-height: 1.4;
  padding: 32px 0;
  border-top: 2px solid var(--ink);
  border-bottom: 2px solid var(--ink);
  position: relative;
}
.pull-quote::before {
  content: '"';
  font-size: 80px;
  color: var(--rust);
  line-height: 1;
  position: absolute;
  top: -10px;
  left: -8px;
  font-style: normal;
}

/* ── IDENTITY GRID ── */
.identity-grid {
  display: grid;
  grid-template-columns: 1fr 1px 1fr 1px 1fr;
  gap: 0;
  margin-top: 48px;
  border: 1px solid rgba(28,26,20,0.15);
}
.identity-cell {
  padding: 40px 36px;
}
.identity-cell-title {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--rust);
  margin-bottom: 16px;
  font-weight: 500;
}
.identity-cell-content {
  font-family: 'Playfair Display', serif;
  font-size: clamp(16px, 2vw, 22px);
  font-style: italic;
  color: var(--ink);
  line-height: 1.5;
}
.identity-cell-note {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.7;
  margin-top: 12px;
}

/* ── INSIGHT SECTION ── */
.insight-section {
  background: var(--ink);
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}
.insight-section::before {
  content: 'BOĞAZ';
  position: absolute;
  font-family: 'Playfair Display', serif;
  font-size: 300px;
  font-weight: 900;
  color: rgba(255,255,255,0.02);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  pointer-events: none;
}
.insight-cols {
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  gap: 0 48px;
  margin-top: 48px;
}
.insight-col-rule { background: rgba(255,255,255,0.1); width: 1px; }
.insight-step {
  padding: 20px 0;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.insight-step:last-child { border: none; }
.insight-step-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--rust);
  margin-bottom: 8px;
}
.insight-step-text {
  font-size: 14px;
  color: rgba(242,234,216,0.65);
  line-height: 1.75;
}
.insight-step-text strong { color: rgba(242,234,216,0.9); font-weight: 500; }
.insight-big {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 3.5vw, 42px);
  font-style: italic;
  color: var(--paper);
  line-height: 1.35;
}
.insight-big em { color: #c0392b; font-style: normal; }

/* ── PLATFORM SECTION ── */
.platform-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 48px;
  border: 1px solid rgba(28,26,20,0.15);
}
.platform-tab {
  padding: 32px 32px;
  border-right: 1px solid rgba(28,26,20,0.1);
  position: relative;
}
.platform-tab:last-child { border: none; }
.platform-name {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 4px;
}
.platform-role {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-style: italic;
  color: var(--muted);
  margin-bottom: 20px;
  line-height: 1.3;
}
.platform-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.8;
  margin-bottom: 20px;
}
.platform-ratio {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.05em;
}
.ratio-bar {
  display: flex;
  height: 4px;
  gap: 2px;
  margin-top: 8px;
  margin-bottom: 4px;
}
.ratio-seg {
  height: 100%;
  border-radius: 1px;
}

/* ── MOCKUP SECTION ── */
.mockups-section {
  background: #1a1814;
  padding: 100px 0;
}

/* Instagram mockup */
.ig-mockup {
  background: #fafafa;
  border-radius: 3px;
  overflow: hidden;
  max-width: 340px;
  font-family: -apple-system, sans-serif;
}
.ig-header {
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid #efefef;
}
.ig-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a3a5c, #2c5f8a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 11px;
  color: white;
  font-weight: 700;
  flex-shrink: 0;
}
.ig-username { font-size: 13px; font-weight: 600; color: #262626; }
.ig-location { font-size: 11px; color: #8e8e8e; }
.ig-image {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.ig-caption-area { padding: 12px 16px; }
.ig-likes { font-size: 13px; font-weight: 600; color: #262626; margin-bottom: 4px; }
.ig-caption { font-size: 13px; color: #262626; line-height: 1.5; }
.ig-caption span { font-weight: 600; }
.ig-time { font-size: 10px; color: #8e8e8e; margin-top: 6px; text-transform: uppercase; letter-spacing: 0.05em; }

/* TikTok mockup */
.tt-mockup {
  background: #000;
  border-radius: 3px;
  overflow: hidden;
  max-width: 200px;
  aspect-ratio: 9/16;
  position: relative;
  font-family: -apple-system, sans-serif;
}
.tt-content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 16px 12px;
}
.tt-username { font-size: 13px; font-weight: 700; color: white; margin-bottom: 4px; }
.tt-caption { font-size: 12px; color: rgba(255,255,255,0.9); line-height: 1.4; margin-bottom: 8px; }
.tt-music { font-size: 10px; color: rgba(255,255,255,0.6); display: flex; align-items: center; gap: 4px; }
.tt-actions {
  position: absolute;
  right: 10px;
  bottom: 80px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  align-items: center;
}
.tt-action { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.tt-action-icon { font-size: 22px; }
.tt-action-count { font-size: 10px; color: white; font-weight: 500; }

/* LinkedIn mockup */
.li-mockup {
  background: white;
  border-radius: 3px;
  overflow: hidden;
  max-width: 440px;
  border: 1px solid #e0e0e0;
  font-family: -apple-system, sans-serif;
}
.li-header {
  padding: 12px 16px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.li-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a3a5c, #2c5f8a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 14px;
  color: white;
  font-weight: 700;
  flex-shrink: 0;
}
.li-name { font-size: 14px; font-weight: 600; color: rgba(0,0,0,0.9); }
.li-title { font-size: 12px; color: rgba(0,0,0,0.6); line-height: 1.4; }
.li-time { font-size: 11px; color: rgba(0,0,0,0.4); }
.li-body { padding: 4px 16px 16px; font-size: 14px; color: rgba(0,0,0,0.8); line-height: 1.7; }
.li-image {
  width: 100%;
  aspect-ratio: 1.91/1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
}
.li-reactions { padding: 8px 16px; border-top: 1px solid #e0e0e0; font-size: 12px; color: rgba(0,0,0,0.5); }

/* ── DO / DON'T SECTION ── */
.rules-grid {
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  gap: 0;
  margin-top: 48px;
  border: 1px solid rgba(28,26,20,0.15);
}
.rules-col { padding: 40px 36px; }
.rules-col-rule { background: rgba(28,26,20,0.1); }
.rules-title {
  font-family: 'Playfair Display', serif;
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 28px;
  line-height: 1;
}
.rule-item {
  display: flex;
  gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(28,26,20,0.06);
  align-items: flex-start;
}
.rule-item:last-child { border: none; }
.rule-icon {
  font-size: 14px;
  flex-shrink: 0;
  margin-top: 2px;
}
.rule-text {
  font-size: 13px;
  line-height: 1.7;
  color: var(--ink);
}
.rule-text em { font-style: italic; color: var(--muted); }

/* ── CLOSING ── */
.closing {
  background: var(--dark);
  padding: 120px 0;
  text-align: center;
  border-top: 4px solid var(--rust);
}
.closing-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(48px, 8vw, 100px);
  font-weight: 900;
  color: var(--paper);
  line-height: 0.9;
  margin-bottom: 24px;
}
.closing-title .water { color: var(--water); font-style: italic; }
.closing-sub {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.15em;
  color: rgba(242,234,216,0.3);
  text-transform: uppercase;
  margin-bottom: 60px;
}
.closing-credits {
  display: flex;
  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
}
.cred { text-align: center; }
.cred-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(242,234,216,0.2);
  margin-bottom: 4px;
}
.cred-value { font-size: 13px; color: rgba(242,234,216,0.45); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}
.fade { animation: fadeUp 0.9s ease forwards; }
.d1 { animation-delay: 0.1s; opacity: 0; }
.d2 { animation-delay: 0.3s; opacity: 0; }
.d3 { animation-delay: 0.5s; opacity: 0; }
.d4 { animation-delay: 0.7s; opacity: 0; }

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .container{padding:0 20px;}
  .identity-grid{grid-template-columns:1fr;}
  .identity-cell.col-rule{display:none;}
  .insight-cols{grid-template-columns:1fr;}
  .insight-col-rule{display:none;}
  .platform-tabs{grid-template-columns:1fr;}
  .rules-grid{grid-template-columns:1fr;}
  .rules-col-rule{display:none;}
  .masthead-top,.masthead-bottom,.masthead-main{padding-left:20px;padding-right:20px;}
  .closing-credits{gap:28px;}
}
</style>
</head>
